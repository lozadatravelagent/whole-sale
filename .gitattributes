# Force LF for source files so contract tests that scan source bytes (e.g.
# staticPrompt.contract.test.ts looking for "\n`;\n") pass identically on
# Windows and Unix. Without this, the Edit tool on Windows rewrites files
# with CRLF and breaks byte-level pattern matching.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
