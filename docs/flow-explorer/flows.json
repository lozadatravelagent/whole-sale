    { "id": "chat-sidebar",         "label": "ChatSidebar",         "sub": "features/chat/components",                "layer": "ui",       "row": 3, "desc": "Conversation list. 'Nueva conversación' button." },
    { "id": "trip-planner-ws",      "label": "TripPlannerWorkspace","sub": "features/trip-planner/components",        "layer": "ui",       "row": 4, "desc": "Trip planner canvas: map + destinations + panels." },
    { "id": "trip-planner-map",     "label": "TripPlannerMap",      "sub": "Mapbox GL component",                     "layer": "ui",       "row": 5, "desc": "Mapbox GL map with markers, popups, viewport events." },
