    { "id": "service",  "label": "Client Services",  "column": 3, "color": "#22d3ee" },
    { "id": "server",   "label": "Server (Edge / Fastify)", "column": 4, "color": "#fb923c" },
    { "id": "db",       "label": "Database",         "column": 5, "color": "#4ade80" },
    { "id": "external", "label": "External APIs",    "column": 6, "color": "#f87171" }
