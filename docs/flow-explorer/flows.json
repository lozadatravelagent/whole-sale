        { "from": "supabase-client",  "to": "create-user-fn",  "label": "POST with JWT",             "payload": "Authorization: Bearer <invoker_jwt>" },
        { "from": "create-user-fn",   "to": "auth-users",      "label": "verify caller",             "payload": "decode JWT, fetch role from public.users" },
        { "from": "create-user-fn",   "to": "users-table",     "label": "role hierarchy guard",      "payload": "SQL: can_create_user_with_role(target_role)" },
        { "from": "create-user-fn",   "to": "auth-users",      "label": "create auth user",          "payload": "admin.createUser({ email, email_confirm:false })" },
        { "from": "auth-users",       "to": "create-user-fn",  "label": "new user id",               "payload": "{ id: uuid }" },
        { "from": "create-user-fn",   "to": "users-table",     "label": "insert profile row",        "payload": "{ id, email, role, tenant_id, agency_id, account_type:'agent' }" },
        { "from": "create-user-fn",   "to": "agencies-table",  "label": "verify agency",             "payload": "SELECT agencies WHERE id=agency_id AND tenant_id matches caller" },
        { "from": "create-user-fn",   "to": "admin-users",     "label": "success + invite sent",     "payload": "{ ok:true, user, inviteUrl }" }
